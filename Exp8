#include <stdio.h>
#include <stdlib.h>

struct node {
    int data;
    struct node *next;
};

struct node *front = NULL, *rear = NULL;

void insertFront(int val) {
    // Insert a node at the front of the deque
    struct node *newnode = (struct node*)malloc(sizeof(struct node));
    newnode->data = val;
    newnode->next = front;
    front = newnode;
    if (rear == NULL) {
        rear = front;
    }
}

void insertRear(int val) {
    // Insert a node at the rear of the deque
    struct node *newnode = (struct node*)malloc(sizeof(struct node));
    newnode->data = val;
    newnode->next = NULL;
    if (rear == NULL) {
        front = rear = newnode;
    } else {
        rear->next = newnode;
        rear = newnode;
    }
}

int deleteFront() {
    // Delete a node from the front of the deque
    if (front == NULL) {
        printf("Deque Underflow\n");
        return -1;
    }
    struct node *temp = front;
    int val = temp->data;
    front = front->next;
    if (front == NULL) {
        rear = NULL;
    }
    free(temp);
    return val;
}

int deleteRear() {
    // Delete a node from the rear of the deque
    if (rear == NULL) {
        printf("Deque Underflow\n");
        return -1;
    }
    struct node *temp = front;
    int val = rear->data;

    if (front == rear) {
        front = rear = NULL;
    } else {
        while (temp->next != rear) {
            temp = temp->next;
        }
        free(rear);
        rear = temp;
        rear->next = NULL;
    }
    return val;
}

int main() {
    int choice, val;
    while (1) {
        printf("1. Insert Front 2. Insert Rear 3. Delete Front 4. Delete Rear 5. Exit: ");
        scanf("%d", &choice);

        if (choice == 1) {
            printf("Enter value: ");
            scanf("%d", &val);
            insertFront(val);
        } else if (choice == 2) {
            printf("Enter value: ");
            scanf("%d", &val);
            insertRear(val);
        } else if (choice == 3) {
            printf("Deleted: %d\n", deleteFront());
        } else if (choice == 4) {
            printf("Deleted: %d\n", deleteRear());
        } else {
            break;
        }
    }
    return 0;
}
