#include <stdio.h>
#define MAX 100

int queue[MAX], front = -1, rear = -1;

void enqueue(int val) {
    // Check for queue overflow
    if (rear == MAX - 1) {
        printf("Queue Overflow\n");
    } else {
        if (front == -1) {
            front = 0;
        }
        queue[++rear] = val;
    }
}

int dequeue() {
    // Check for queue underflow
    if (front == -1 || front > rear) {
        printf("Queue Underflow\n");
        return -1;
    } else {
        return queue[front++];
    }
}

int main() {
    int choice, val;
    while (1) {
        printf("1. Enqueue 2. Dequeue 3. Exit: ");
        scanf("%d", &choice);

        if (choice == 1) {
            printf("Enter value: ");
            scanf("%d", &val);
            enqueue(val);
        } else if (choice == 2) {
            printf("Dequeued: %d\n", dequeue());
        } else {
            break;
        }
    }
    return 0;
}
